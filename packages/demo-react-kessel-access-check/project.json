{
  "name": "demo-react-kessel-access-check",
  "projectType": "application",
  "tags": ["type:app", "scope:example"],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "outputPath": "packages/demo-react-kessel-access-check/dist",
        "skipTypeCheck": true,
        "configFile": "packages/demo-react-kessel-access-check/vite.config.ts"
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "options": {
        "buildTarget": "demo-react-kessel-access-check:build"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx eslint .",
        "cwd": "packages/demo-react-kessel-access-check"
      }
    }
  }
}
