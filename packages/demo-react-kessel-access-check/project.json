{
  "name": "demo-react-kessel-access-check",
  "projectType": "application",
  "tags": ["type:app", "scope:example"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "npx vite build",
        "cwd": "packages/demo-react-kessel-access-check"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx eslint .",
        "cwd": "packages/demo-react-kessel-access-check"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vite",
        "cwd": "packages/demo-react-kessel-access-check"
      }
    }
  }
}
